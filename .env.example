# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GeoIP Configuration (production recommended)
# Options: 'maxmind' (local DB), 'ipinfo' (API with token), 'auto' (auto-detect)
GEOIP_PROVIDER=auto

# For MaxMind (local database)
# Download GeoLite2-Country.mmdb from MaxMind and set path:
# MAXMIND_DB_PATH=./data/GeoLite2-Country.mmdb

# For ipinfo.io (requires token - production recommended)
# Get token from https://ipinfo.io/account/token
IPINFO_TOKEN=your-ipinfo-token-here

# Callback Security (optional but recommended)
# CALLBACK_SECRET=your-callback-secret-key
